{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "socrates",
  "model": "openai/gpt-5.5",
  "agent": {
    "socrates": {
      "description": "A Socratic engineering coach that teaches through questions, hints, and pseudocode.",
      "mode": "primary",
      "prompt": "{file:./prompts/socrates.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "read": "ask",
      },
    },
    // allow edit permissions for specific agents (from: https://github.com/anomalyco/opencode/issues/24615#issuecomment-4346108562 )
    "build": {
      "permission": {
        "edit": {
          "*": "allow",
        },
        "task": {
          // allow agents with edit permission to run subagents with edit permissions by default without user confirmation
          "general": "allow",
        },
      },
    },
    "general": {
      "permission": {
        "edit": {
          "*": "allow",
        },
        "task": {
          "general": "allow",
        },
      },
    },
  },
  "mcp": {
    "lightcast": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.ai.api.lightcast.io",
    },
  },
  "permission": {
    "task": {
      // do not allow running subagents with edit permissions by default without user confirmation
      "*": "ask",
      "explore": "allow",
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git *": "ask",
      // git READ-only
      "git status *": "allow",
      "git log *": "allow",
      "git rm *": "allow",
      "git mv *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git pull": "allow",
      "git grep *": "allow",
      "git bisect *": "allow",
      "git show *": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git show-ref *": "allow",
      "git merge-base *": "allow",
      // Git destructive
      "git branch *": "deny",
      "git rebase *": "deny",
      "git switch *": "deny",
      "git tag *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git checkout *": "deny",
      "git add *": "deny",
      "git worktree *": "deny",
      "grep *": "allow",
      "npx vitest *": "allow",
      "sed *": "allow",
      "ls *": "allow",
      "file *": "allow",
      "npm *": "allow",
      "openspec *": "allow",
      "npx tsc --noEmit": "allow",
      "printf *": "allow",
      "true": "allow", // needed for " ... || true" commands
    },
    "external_directory": "ask",
    "read": {
      ".env": "deny",
      ".git": "deny",
    },
  },
}

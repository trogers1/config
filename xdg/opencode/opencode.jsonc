{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "socrates",
  "model": "openai/gpt-5.4",
  "agent": {
    "socrates": {
      "description": "A Socratic engineering coach that teaches through questions, hints, and pseudocode.",
      "mode": "primary",
      "prompt": "{file:./prompts/socrates.md}",
      "permission": {
        "edit": "deny",
      },
    },
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "ask",
      // git READ-only
      "git status*": "allow",
      "git status *": "allow",
      "git log*": "allow",
      "git log *": "allow",
      "git rm *": "allow",
      "git mv *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git pull": "allow",
      "git grep *": "allow",
      "git bisect *": "allow",
      "git show *": "allow",
      "git ls-files *": "allow",
      "git rev-parse *": "allow",
      "git show-ref *": "allow",
      // Git destructive
      "git branch *": "deny",
      "git rebase *": "deny",
      "git switch *": "deny",
      "git tag *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git checkout *": "deny",
      "git add *": "deny",
      "git worktree *": "deny",
      "grep *": "allow",
      "npx vitest *": "allow",
      "sed *": "allow",
      "ls *": "allow",
      "file *": "allow",
      "npm *": "allow",
      "openspec *": "allow",
      "npx tsc --noEmit": "allow",
    },
    "external_directory": "ask",
    "read": {
      ".env": "deny",
    },
  },
}

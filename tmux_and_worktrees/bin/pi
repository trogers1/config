#!/bin/bash
set -euo pipefail

export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  echo "nvm is not installed at $NVM_DIR" >&2
  exit 1
fi

# shellcheck source=/dev/null
. "$NVM_DIR/nvm.sh" --no-use

pi_path="$(find "$NVM_DIR/versions/node" -path '*/bin/pi' 2>/dev/null | sort -V | tail -n1)"
if [ -z "$pi_path" ]; then
  echo "pi is not installed in any nvm-managed Node version" >&2
  exit 1
fi

pi_node_version="$(basename "$(dirname "$(dirname "$pi_path")")")"
nvm use --silent "$pi_node_version" >/dev/null 2>&1 || true

exec "$pi_path" "$@"

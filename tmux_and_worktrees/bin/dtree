#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/lib/tmux_worktree.sh"

log() {
    printf "[dtree] %s\n" "$*"
}

default_primary_branch() {
    local remote_head=""

    remote_head="$(git -C "$repo_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
    if [ -n "$remote_head" ]; then
        printf '%s\n' "${remote_head#origin/}"
    elif git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
        printf '%s\n' "main"
    elif git -C "$repo_root" show-ref --verify --quiet refs/heads/master; then
        printf '%s\n' "master"
    else
        printf '%s\n' ""
    fi
}

prompt_to_convert_main_checkout() {
    local primary_branch="$1"
    local response=""

    printf '\n[dtree] %s is already checked out in the primary checkout: %s\n' "$branch" "$repo_root" >&2
    printf '[dtree] Turn it into a worktree at %s? The primary checkout will switch to %s. [y/N] ' "$default_wt_path" "$primary_branch" >&2

    if ! read -r response </dev/tty; then
        printf '\n[dtree] Cannot read a confirmation; leaving the branch in the primary checkout.\n' >&2
        return 1
    fi

    case "$response" in
        y|Y|yes|YES|Yes)
            return 0
            ;;
        *)
            printf '[dtree] Leaving the branch in the primary checkout.\n' >&2
            return 1
            ;;
    esac
}

run_bootstrap() {
    local repo_root="$1"
    local wt_path="$2"
    local bootstrap_script=""

    if [ -f "$repo_root/.worktree-init.sh" ]; then
        bootstrap_script="$repo_root/.worktree-init.sh"
    elif [ -f "$repo_root/scripts/worktree-init.sh" ]; then
        bootstrap_script="$repo_root/scripts/worktree-init.sh"
    fi

    if [ -n "$bootstrap_script" ]; then
        log "Running bootstrap script: $bootstrap_script"
        (cd "$wt_path" && REPO_ROOT="$repo_root" WORKTREE_PATH="$wt_path" bash "$bootstrap_script")
        return
    fi

    if [ ! -e "$wt_path/.env" ] && [ -f "$repo_root/.env" ]; then
        ln -s "$repo_root/.env" "$wt_path/.env"
        log "Linked .env from main checkout"
    fi

    if [ -f "$wt_path/package.json" ] && [ ! -d "$wt_path/node_modules" ]; then
        if command -v npm >/dev/null 2>&1; then
            if [ -f "$wt_path/package-lock.json" ]; then
                log "Installing dependencies with npm ci"
                (cd "$wt_path" && npm ci)
            else
                log "Installing dependencies with npm install"
                (cd "$wt_path" && npm install)
            fi
        else
            log "Skipped dependency install (npm not found)"
        fi
    fi
}

branch="${1:-}"
base_branch="${2:-}"

tmux_worktree_require_git
tmux_worktree_require_tmux
tmux_worktree_require_git_repo

current_branch="$(tmux_worktree_git_current_branch)"

if [ -z "$branch" ]; then
    if [ -n "$current_branch" ]; then
        branch="$current_branch"
    else
        echo "Usage: dtree <branch> [base-branch]"
        exit 1
    fi
fi

if [ -z "$base_branch" ]; then
    base_branch="$current_branch"
    if [ -z "$base_branch" ]; then
        base_branch="main"
    fi
fi

repo_root="$(tmux_worktree_main_repo_root)"
repo_name="$(basename "$repo_root")"
worktree_root="$(tmux_worktree_default_root "$repo_root")"
default_wt_path="$(tmux_worktree_default_path "$repo_root" "$branch")"

existing_wt_path="$(tmux_worktree_path_for_branch "$repo_root" "$branch")"
created_worktree=false

# A branch checked out in the primary checkout cannot also be added as a
# worktree. Offer to move the primary checkout to its default branch first.
if [ "$existing_wt_path" = "$repo_root" ] && [ "$current_branch" = "$branch" ]; then
    primary_branch="$(default_primary_branch)"

    if [ -z "$primary_branch" ] || [ "$primary_branch" = "$branch" ]; then
        echo "[dtree] Cannot choose a primary branch. Set origin/HEAD or create main/master before rerunning." >&2
        exit 1
    fi

    if [ -n "$(git -C "$repo_root" status --porcelain)" ]; then
        echo "[dtree] Cannot turn $branch into a worktree because the primary checkout has uncommitted changes. Commit or stash them first." >&2
        exit 1
    fi

    if prompt_to_convert_main_checkout "$primary_branch"; then
        main_session_name="$(tmux_worktree_find_session_for_worktree_path "$repo_root" || true)"
        git -C "$repo_root" checkout "$primary_branch"
        if [ -n "$main_session_name" ]; then
            tmux_worktree_set_session_metadata "$main_session_name" "$repo_root" "$primary_branch"
        fi
        existing_wt_path=""
    fi
fi

if [ -n "$existing_wt_path" ]; then
    wt_path="$existing_wt_path"
else
    wt_path="$default_wt_path"
    mkdir -p "$worktree_root"

    if [ -d "$wt_path" ]; then
        echo "Worktree already exists at $wt_path"
    else
        if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
            git -C "$repo_root" worktree add "$wt_path" "$branch"
        else
            git -C "$repo_root" worktree add -b "$branch" "$wt_path" "$base_branch"
        fi
        created_worktree=true
    fi
fi

preferred_session_name="$(tmux_worktree_preferred_worktree_session_name "$repo_name" "$branch")"
session_name="$(tmux_worktree_find_session_for_worktree_path "$wt_path" || true)"

if [ -n "$session_name" ]; then
    tmux_worktree_set_session_metadata "$session_name" "$wt_path" "$branch"
    tmux_worktree_attach_or_switch "$session_name"
    exit 0
fi

session_name="$preferred_session_name"
if tmux has-session -t "$session_name" 2>/dev/null; then
    session_name="$(tmux_worktree_make_session_name "${preferred_session_name}-$(tmux_worktree_path_checksum "$wt_path")")"
    log "Session $preferred_session_name is already attached to another worktree; using $session_name"
fi

if [ "$created_worktree" = true ]; then
    run_bootstrap "$repo_root" "$wt_path"
fi

tmux_worktree_create_standard_session "$session_name" "$wt_path" "$branch"
tmux_worktree_attach_or_switch "$session_name"

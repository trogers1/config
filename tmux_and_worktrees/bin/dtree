#!/bin/bash
set -euo pipefail

log() {
    printf "[dtree] %s\n" "$*"
}

attach_or_switch() {
    local session_name="$1"

    if [ -n "${TMUX:-}" ]; then
        tmux switch-client -t "$session_name"
    else
        tmux attach-session -t "$session_name"
    fi
}

get_session_worktree_path() {
    local session_name="$1"
    local env_line=""

    env_line="$(tmux show-environment -t "$session_name" DTREE_WORKTREE_PATH 2>/dev/null || true)"
    case "$env_line" in
        DTREE_WORKTREE_PATH=*)
            printf '%s\n' "${env_line#DTREE_WORKTREE_PATH=}"
            return 0
            ;;
    esac

    return 1
}

find_session_for_worktree_path() {
    local target_path="$1"
    local session_name=""
    local session_path=""

    while IFS= read -r session_name; do
        [ -n "$session_name" ] || continue

        session_path="$(get_session_worktree_path "$session_name" || true)"
        if [ "$session_path" = "$target_path" ]; then
            printf '%s\n' "$session_name"
            return 0
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)

    return 1
}

make_session_name() {
    printf '%s\n' "$1" | tr '/:.' '---'
}

path_checksum() {
    local input_path="$1"
    local checksum=""

    checksum="$(printf '%s' "$input_path" | cksum)"
    printf '%s\n' "${checksum%% *}"
}

run_bootstrap() {
    local repo_root="$1"
    local wt_path="$2"
    local bootstrap_script=""

    if [ -f "$repo_root/.worktree-init.sh" ]; then
        bootstrap_script="$repo_root/.worktree-init.sh"
    elif [ -f "$repo_root/scripts/worktree-init.sh" ]; then
        bootstrap_script="$repo_root/scripts/worktree-init.sh"
    fi

    if [ -n "$bootstrap_script" ]; then
        log "Running bootstrap script: $bootstrap_script"
        (cd "$wt_path" && REPO_ROOT="$repo_root" WORKTREE_PATH="$wt_path" bash "$bootstrap_script")
        return
    fi

    if [ ! -e "$wt_path/.env" ] && [ -f "$repo_root/.env" ]; then
        ln -s "$repo_root/.env" "$wt_path/.env"
        log "Linked .env from main checkout"
    fi

    if [ -f "$wt_path/package.json" ] && [ ! -d "$wt_path/node_modules" ]; then
        if command -v npm >/dev/null 2>&1; then
            if [ -f "$wt_path/package-lock.json" ]; then
                log "Installing dependencies with npm ci"
                (cd "$wt_path" && npm ci)
            else
                log "Installing dependencies with npm install"
                (cd "$wt_path" && npm install)
            fi
        else
            log "Skipped dependency install (npm not found)"
        fi
    fi
}

branch="${1:-}"
base_branch="${2:-}"

if ! command -v git >/dev/null 2>&1; then
    echo "git is required"
    exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
    echo "tmux is required"
    exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Run this from inside a git repository or worktree."
    exit 1
fi

current_branch="$(git symbolic-ref --quiet --short HEAD || true)"

if [ -z "$branch" ]; then
    if [ -n "$current_branch" ]; then
        branch="$current_branch"
    else
        echo "Usage: dtree <branch> [base-branch]"
        exit 1
    fi
fi

if [ -z "$base_branch" ]; then
    base_branch="$current_branch"
    if [ -z "$base_branch" ]; then
        base_branch="main"
    fi
fi

git_common_dir="$(git rev-parse --git-common-dir)"
repo_root="$(cd "${git_common_dir}/.." && pwd)"
repo_name="$(basename "$repo_root")"
container_dir="$(dirname "$repo_root")"

wk_dir="$container_dir/wk"
default_wt_path="$wk_dir/$branch"

existing_wt_path=""
current_wt_path=""
while IFS= read -r line; do
    case "$line" in
        worktree\ *)
            current_wt_path="${line#worktree }"
            ;;
        branch\ refs/heads/*)
            if [ "${line#branch }" = "refs/heads/$branch" ]; then
                existing_wt_path="$current_wt_path"
                break
            fi
            ;;
    esac
done < <(git -C "$repo_root" worktree list --porcelain)

if [ -n "$existing_wt_path" ]; then
    wt_path="$existing_wt_path"
else
    wt_path="$default_wt_path"
    mkdir -p "$wk_dir"

    if [ -d "$wt_path" ]; then
        echo "Worktree already exists at $wt_path"
    else
        if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
            git -C "$repo_root" worktree add "$wt_path" "$branch"
        else
            git -C "$repo_root" worktree add -b "$branch" "$wt_path" "$base_branch"
        fi
    fi
fi

preferred_session_name="$(make_session_name "${repo_name}-${branch}")"
session_name="$(find_session_for_worktree_path "$wt_path" || true)"

if [ -n "$session_name" ]; then
    attach_or_switch "$session_name"
    exit 0
fi

session_name="$preferred_session_name"
if tmux has-session -t "$session_name" 2>/dev/null; then
    session_name="$(make_session_name "${preferred_session_name}-$(path_checksum "$wt_path")")"
    log "Session $preferred_session_name is already attached to another worktree; using $session_name"
fi

run_bootstrap "$repo_root" "$wt_path"

tmux new-session -d -s "$session_name" -n nvim -c "$wt_path"
tmux set-environment -t "$session_name" DTREE_WORKTREE_PATH "$wt_path"
tmux set-environment -t "$session_name" DTREE_BRANCH "$branch"
tmux send-keys -t "$session_name:nvim" "nvim" C-m

tmux new-window -t "$session_name:" -n opencode -c "$wt_path"
tmux send-keys -t "$session_name:opencode" "opencode" C-m

tmux new-window -t "$session_name:" -n lazygit -c "$wt_path"
tmux send-keys -t "$session_name:lazygit" "lazygit" C-m

tmux new-window -t "$session_name:" -n term -c "$wt_path"
tmux select-window -t "$session_name:nvim"

attach_or_switch "$session_name"

#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/lib/tmux_worktree.sh"

target_path="${1:-$(pwd)}"

if [ ! -d "$target_path" ]; then
    echo "Path does not exist: $target_path"
    exit 1
fi

tmux_worktree_require_tmux

project_path="$(tmux_worktree_resolve_project_path "$target_path")"
preferred_session_name="$(tmux_worktree_preferred_local_session_name "$project_path")"
session_name="$(tmux_worktree_find_session_for_worktree_path "$project_path" || true)"

if [ -n "$session_name" ]; then
    tmux_worktree_set_session_metadata "$session_name" "$project_path"
    tmux_worktree_attach_or_switch "$session_name"
    exit 0
fi

session_name="$preferred_session_name"
if tmux has-session -t "$session_name" 2>/dev/null; then
    session_name="$(tmux_worktree_make_session_name "${preferred_session_name}-$(tmux_worktree_path_checksum "$project_path")")"
fi

tmux_worktree_create_standard_session "$session_name" "$project_path"
tmux_worktree_attach_or_switch "$session_name"

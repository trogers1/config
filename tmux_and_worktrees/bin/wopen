#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

target_path="${1:-$(pwd)}"

if [ ! -d "$target_path" ]; then
    echo "Path does not exist: $target_path"
    exit 1
fi

. "$SCRIPT_DIR/lib/tmux_worktree.sh"

tmux_worktree_require_tmux

project_path="$(tmux_worktree_resolve_project_path "$target_path")"
session_name="$(tmux_worktree_find_session_for_worktree_path "$project_path" || true)"

if [ -n "$session_name" ]; then
    pane_current_command="$(tmux list-panes -t "$session_name:nvim" -F '#{pane_current_command}' 2>/dev/null || true)"

    if [ "$pane_current_command" = "nvim" ]; then
        tmux send-keys -t "$session_name:nvim" Escape ":let $NVIM_CONTEXT='writing' | set background=light | colorscheme shine" Enter
    else
        tmux send-keys -t "$session_name:nvim" "env NVIM_CONTEXT=writing NVIM_BACKGROUND=light NVIM_COLORSCHEME=shine nvim" C-m
    fi

    tmux_worktree_attach_or_switch "$session_name"
    exit 0
fi

exec "$SCRIPT_DIR/dnew" --nvim-command 'env NVIM_CONTEXT=writing NVIM_BACKGROUND=light NVIM_COLORSCHEME=shine nvim' "$project_path"

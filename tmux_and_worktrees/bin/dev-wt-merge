#!/bin/bash
set -euo pipefail

branch="${1:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)}"
main_branch="${2:-main}"
keep_worktree="${3:-}"

if [ -z "$branch" ]; then
    echo "Usage: dev-wt-merge <branch> [main-branch] [--keep]"
    exit 1
fi

if [ "$branch" = "$main_branch" ]; then
    echo "Refusing to merge '$main_branch' into itself."
    exit 1
fi

if ! command -v git >/dev/null 2>&1; then
    echo "git is required"
    exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Run this from inside a git repository or worktree."
    exit 1
fi

git_common_dir="$(git rev-parse --git-common-dir)"
repo_root="$(cd "${git_common_dir}/.." && pwd)"
repo_name="$(basename "$repo_root")"
session_name="$(printf "%s-%s" "$repo_name" "$branch" | tr '/:.' '---')"

if [ -n "$(git status --porcelain)" ]; then
    echo "Current working tree is dirty. Commit/stash first."
    exit 1
fi

if [ -n "$(git -C "$repo_root" status --porcelain)" ]; then
    echo "Main repo checkout is dirty: $repo_root"
    exit 1
fi

git -C "$repo_root" checkout "$main_branch"
git -C "$repo_root" merge --no-ff "$branch"

if [ "$keep_worktree" != "--keep" ]; then
    wt_path="$(git -C "$repo_root" worktree list --porcelain | awk -v target="refs/heads/$branch" '
        $1 == "worktree" { path = $2 }
        $1 == "branch" && $2 == target { print path; exit }
    ')"

    if [ -n "$wt_path" ]; then
        git -C "$repo_root" worktree remove "$wt_path"
    fi

    git -C "$repo_root" branch -d "$branch" || true
    if command -v tmux >/dev/null 2>&1; then
        tmux kill-session -t "$session_name" 2>/dev/null || true
    fi
fi

echo "Merged '$branch' into '$main_branch'."
